{
  "type": "object",
  "required": ["parts"],
  "properties": {
    "parts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["nr", "mat", "anz", "width", "height", "rotation", "holes", "subdimensions"],
        "properties": {
          "nr": { "type": ["string", "null"] },
          "mat": { "type": ["string", "null"] },
          "anz": { "type": "string" },
          "width": { "type": ["integer", "null"] },
          "height": { "type": ["integer", "null"] },
          "rotation": { "type": "integer", "enum": [0, 90, 180, 270] },
          "holes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": ["integer", "null"] },
                "y": { "type": ["integer", "null"] }
              }
            }
          },
          "subdimensions": {
            "description": "Printed dimension segments used to compute hole positions. Not shown on output.",
            "type": "array",
            "items": {
              "type": "object",
              "required": ["value", "x1", "y1", "x2", "y2", "rotation"],
              "properties": {
                "value": { "type": ["integer", "null"] },
                "x1": { "type": ["integer", "null"] },
                "y1": { "type": ["integer", "null"] },
                "x2": { "type": ["integer", "null"] },
                "y2": { "type": ["integer", "null"] },
                "rotation": { "type": "integer", "enum": [0, 90, 180, 270] }
              }
            }
          }
        }
      }
    }
  }
}
