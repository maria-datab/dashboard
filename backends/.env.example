# Unified backend env — copy to backends/.env and fill secrets.
# Shared keys once; per-app settings use BOXOUT_* / SIMPLE_PARTS_* prefixes.
# Default setup: remote Rhino.Compute (no local rhino.compute.exe from run-*.bat).

# ── Shared ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Boxout (Flask :5000 — remote Compute) ───────────────────────────────────
BOXOUT_PORT=5000
BOXOUT_FLASK_DEBUG=1
BOXOUT_FLASK_HOST=127.0.0.1
BOXOUT_COMPUTE_BASE_URL=http://13.63.222.45
BOXOUT_COMPUTE_API_KEY=
BOXOUT_COMPUTE_TIMEOUT_SECONDS=120
BOXOUT_DEFINITIONS_DIR=definitions
BOXOUT_DEFAULT_DEFINITION_ID=joint-wiz

# ── Simple Parts (Flask :5001 — remote Compute) ─────────────────────────────
SIMPLE_PARTS_PORT=5001
SIMPLE_PARTS_FLASK_HOST=127.0.0.1
SIMPLE_PARTS_FLASK_DEBUG=1
SIMPLE_PARTS_RUN_LOCALLY=false
SIMPLE_PARTS_COMPUTE_BASE_URL_LOCAL=http://127.0.0.1:5000
SIMPLE_PARTS_COMPUTE_API_KEY_LOCAL=
SIMPLE_PARTS_COMPUTE_BASE_URL_PROD=http://13.63.222.45
SIMPLE_PARTS_COMPUTE_API_KEY_PROD=
SIMPLE_PARTS_COMPUTE_TIMEOUT_SECONDS=180
SIMPLE_PARTS_COMPUTE_CSV_TEMP_BASE=C:/Temp/simple-parts-nesting
SIMPLE_PARTS_DEFINITIONS_DIR=definitions
SIMPLE_PARTS_DEFAULT_DEFINITION_ID=simple-parts-summon2d-nesting
SIMPLE_PARTS_SCAN_TARGET_LONG_EDGE=1568
SIMPLE_PARTS_SCAN_MIN_LONG_EDGE=1200
SIMPLE_PARTS_SCAN_ENHANCE_CONTRAST=true
